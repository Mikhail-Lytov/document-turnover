<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<fx:root fx:id="root" prefHeight="574.0" prefWidth="1186.0" styleClass="app-root" type="BorderPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.desktop.document.turnover.controller.MainView">
   <left>
      <VBox prefWidth="286.0" spacing="14.0" styleClass="app-nav" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
         </padding>
         <children>
            <VBox spacing="2.0" styleClass="brand-block">
               <padding>
                  <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
               </padding>
               <children>
                  <Label styleClass="brand-title" text="Имя программы" />
                  <Label styleClass="brand-subtitle" text="Имя компании" />
               </children>
            </VBox>
            <Separator />
            <Label styleClass="section-label" text="РАЗДЕЛЫ" />
            <ToggleButton fx:id="converterNavButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#converterButtonClick" prefHeight="54.0" styleClass="nav-item" text="Конвертация" wrapText="true" />
            <ToggleButton fx:id="alphabetNavButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#searchByAlphabetButtonClick" prefHeight="54.0" styleClass="nav-item" text="Поиск с заменой по алфавиту" wrapText="true" />
            <ToggleButton fx:id="searchDocumentsNavButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#searchDocumentsButtonClick" prefHeight="54.0" styleClass="nav-item" text="Поиск по документам" wrapText="true" />
            <Region VBox.vgrow="ALWAYS" />
            <VBox spacing="8.0" styleClass="theme-switcher">
               <children>
                  <Label styleClass="section-label" text="ТЕМА" />
                  <HBox spacing="8.0">
                     <children>
                        <ToggleButton fx:id="lightThemeButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#lightThemeButtonClick" prefHeight="38.0" styleClass="theme-button" text="Светлая">
                           <HBox.hgrow>
                              <Priority fx:constant="ALWAYS" />
                           </HBox.hgrow>
                        </ToggleButton>
                        <ToggleButton fx:id="darkThemeButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#darkThemeButtonClick" prefHeight="38.0" styleClass="theme-button" text="Черная">
                           <HBox.hgrow>
                              <Priority fx:constant="ALWAYS" />
                           </HBox.hgrow>
                        </ToggleButton>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <StackPane fx:id="contentContainer" styleClass="app-content" BorderPane.alignment="CENTER" />
   </center>
</fx:root>
